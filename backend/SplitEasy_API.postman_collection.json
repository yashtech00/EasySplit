						"description": "Logout from all devices."
					},
					"response": [
						{
							"name": "✅ Success",
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"body": "{\n  \"success\": true,\n  \"message\": \"Logged out from all devices\",\n  \"data\": null\n}"
