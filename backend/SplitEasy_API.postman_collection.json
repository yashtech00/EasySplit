{
	"info": {
		"_postman_id": "spliteasy-api-v1",
		"name": "SplitEasy API v1.0",
		"description": "Complete API collection for SplitEasy - Expense Splitting Application with UPI Integration\n\n## Base URL\nDevelopment: http://localhost:8000\n\n## Authentication\nMost endpoints require Bearer token authentication. Use the access token received from login.\n\n## Environment Variables\n- base_url: API base URL\n- access_token: JWT access token\n- refresh_token: JWT refresh token\n- user_id: Current user ID\n- group_id: Test group ID\n- expense_id: Test expense ID",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "🔐 Authentication",
			"item": [
				{
					"name": "Send OTP",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"mobile\": \"9876543210\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/auth/send-otp",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "auth", "send-otp"]
						},
						"description": "Send OTP to mobile number. Rate limited to 5 requests per 15 minutes per IP."
					},
					"response": [
						{
							"name": "✅ Success",
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"body": "{\n  \"success\": true,\n  \"message\": \"OTP sent successfully\",\n  \"data\": null\n}"
						},
						{
							"name": "❌ Invalid Mobile",
							"status": "Bad Request",
							"code": 400,
							"_postman_previewlanguage": "json",
							"body": "{\n  \"success\": false,\n  \"message\": \"Validation failed\"\n}"
						},
						{
							"name": "⏱️ Rate Limited",
							"status": "Too Many Requests",
							"code": 429,
							"_postman_previewlanguage": "json",
							"body": "{\n  \"success\": false,\n  \"message\": \"Too many OTP requests, please try again later\"\n}"
						}
					]
				},
				{
					"name": "Verify OTP & Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.environment.set(\"access_token\", jsonData.data.accessToken);",
									"    pm.environment.set(\"refresh_token\", jsonData.data.refreshToken);",
									"    pm.environment.set(\"user_id\", jsonData.data.user.id);",
									"    console.log(\"✅ Tokens saved to environment\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"mobile\": \"9876543210\",\n  \"otp\": \"123456\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/auth/verify-otp",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "auth", "verify-otp"]
						},
						"description": "Verify OTP and login/register user. Returns JWT tokens."
					},
					"response": [
						{
							"name": "✅ New User",
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"body": "{\n  \"success\": true,\n  \"message\": \"Login successful\",\n  \"data\": {\n    \"user\": {\n      \"id\": \"cm5abc123xyz\",\n      \"mobile\": \"9876543210\",\n      \"name\": null,\n      \"upiId\": null,\n      \"expoPushToken\": null,\n      \"isNewUser\": true\n    },\n    \"accessToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiJjbTVhYmMxMjN4eXoiLCJpYXQiOjE3MDUzMjAwMDAsImV4cCI6MTcwNTMyMDkwMH0.signature\",\n    \"refreshToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiJjbTVhYmMxMjN4eXoiLCJpYXQiOjE3MDUzMjAwMDAsImV4cCI6MTcwNzkxMjAwMH0.signature\"\n  }\n}"
						},
						{
							"name": "✅ Existing User",
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"body": "{\n  \"success\": true,\n  \"message\": \"Login successful\",\n  \"data\": {\n    \"user\": {\n      \"id\": \"cm5abc123xyz\",\n      \"mobile\": \"9876543210\",\n      \"name\": \"Rahul Sharma\",\n      \"upiId\": \"rahul@paytm\",\n      \"expoPushToken\": \"ExponentPushToken[xxxxxxxxxxxxxxxxxxxxxx]\",\n      \"isNewUser\": false\n    },\n    \"accessToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n    \"refreshToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\"\n  }\n}"
						},
						{
							"name": "❌ Invalid OTP",
							"status": "Unauthorized",
							"code": 401,
							"_postman_previewlanguage": "json",
							"body": "{\n  \"success\": false,\n  \"message\": \"Invalid or expired OTP\"\n}"
						}
					]
				},
