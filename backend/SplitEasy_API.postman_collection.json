							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"body": "{\n  \"success\": true,\n  \"message\": \"Profile updated successfully\",\n  \"data\": {\n    \"id\": \"cm5abc123xyz\",\n    \"mobile\": \"9876543210\",\n    \"name\": \"Rahul Sharma\",\n    \"upiId\": \"rahul@paytm\",\n    \"expoPushToken\": null\n  }\n}"
